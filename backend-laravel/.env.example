APP_NAME="Brunch Bouaké Backend API"
APP_ENV=local
APP_KEY=base64:3t6qY+gQ+L0vUqV7jE+3vDkO6+X8fE+3vDkO6=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
